{
  "name": "@openclaw/services",
  "version": "1.1.0",
  "private": true,
  "description": "OpenClaw Infrastructure Services Monorepo - Bun Runtime",
  "type": "module",
  "workspaces": [
    "services/*",
    "cli"
  ],
  "scripts": {
    "install:all": "bun install && bash scripts/install.sh",
    "start": "bun run --filter '*' start",
    "build": "bash scripts/build.sh",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint .",
    "clean": "rm -rf node_modules services/*/node_modules cli/node_modules dist"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "typescript": "^5.0.0",
    "@types/bun": "^1.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
