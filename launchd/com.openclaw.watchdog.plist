<?xml version="1.0" encoding="UTF-8"?>
<!--
  示例模板 - CLI 会动态生成，无需手动替换 USERNAME
  安装命令: openclaw-services setup
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>node</string>
        <string>/Users/USERNAME/.openclaw/services/watchdog/index.js</string>
        <string>watch</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>OPENCLAW_SERVICES_HOME</key>
        <string>/Users/USERNAME/.openclaw</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/USERNAME/.openclaw/logs/watchdog.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/USERNAME/.openclaw/logs/watchdog.error.log</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
